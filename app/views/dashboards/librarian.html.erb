<div class="row mb-4">
  <div class="col-md-12">
    <h1><i class="fas fa-chart-line"></i> Librarian Dashboard</h1>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary">
      <div class="card-body">
        <h5 class="card-title">Total Books</h5>
        <p class="card-text display-4"><%= Book.count %></p>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card text-white bg-info">
      <div class="card-body">
        <h5 class="card-title">Books Borrowed</h5>
        <p class="card-text display-4"><%= Borrow.active.count %></p>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card text-white bg-warning">
      <div class="card-body">
        <h5 class="card-title">Due Today</h5>
        <p class="card-text display-4"><%= Borrow.due_today.count %></p>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card text-white bg-danger">
      <div class="card-body">
        <h5 class="card-title">Overdue Books</h5>
        <p class="card-text display-4"><%= Borrow.overdue.count %></p>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-header">
        <h5><i class="fas fa-history"></i> Overdue Books</h5>
      </div>
      <div class="card-body">
        <% overdue_borrows = Borrow.overdue.includes(:user, :book) %>
        <% if overdue_borrows.any? %>
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>User</th>
                <th>Book</th>
                <th>Borrowed Date</th>
                <th>Due Date</th>
                <th>Days Overdue</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% overdue_borrows.each do |borrow| %>
                <tr>
                  <td><strong><%= borrow.user.email %></strong></td>
                  <td><%= link_to borrow.book.title, book_path(borrow.book) %></td>
                  <td><%= borrow.borrowed_at.strftime("%B %d, %Y") %></td>
                  <td>
                    <span class="badge bg-danger"><%= borrow.due_at.strftime("%B %d, %Y") %></span>
                  </td>
                  <td><strong><%= borrow.days_overdue %> days</strong></td>
                  <td>
                    <%= button_to "Mark Returned", borrow_path(borrow), method: :patch, params: { returned: true }, class: "btn btn-success btn-sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="alert alert-success" role="alert">
            <i class="fas fa-check-circle"></i> No overdue books.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
