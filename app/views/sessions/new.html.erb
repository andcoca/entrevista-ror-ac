<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card">
        <div class="card-body">
          <h2 class="card-title text-center mb-4"><i class="fas fa-sign-in-alt"></i> Sign In</h2>

          <%= form_with url: sessions_path, scope: :session, method: :post, local: true do |form| %>
            <div class="mb-3">
              <%= form.label :email, class: "form-label" %>
              <%= form.email_field :email, class: "form-control", required: true, autofocus: true %>
            </div>

            <div class="mb-3">
              <%= form.label :password, class: "form-label" %>
              <%= form.password_field :password, class: "form-control", required: true %>
            </div>

            <div class="d-grid">
              <%= form.submit "Sign In", class: "btn btn-primary" %>
            </div>
          <% end %>

          <hr>

          <div class="text-center">
            <p>Don't have an account? <%= link_to "Sign Up", new_registration_path %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
